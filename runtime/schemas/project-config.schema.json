{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vijai.local/schemas/project-config.schema.json",
  "title": "Vijai project configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion"],
  "properties": {
    "$schema": {"type": "string"},
    "schemaVersion": {"const": 1},
    "editor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tabSize": {"type": "integer", "minimum": 1, "maximum": 16, "default": 4},
        "formatOnSave": {"type": "boolean", "default": false}
      }
    },
    "tasks": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command"],
        "properties": {
          "command": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "cwd": {"type": "string"},
          "shell": {"type": "boolean", "default": false}
        }
      }
    },
    "agents": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultProvider": {"enum": ["codex", "copilot"], "default": "codex"},
        "excludes": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
